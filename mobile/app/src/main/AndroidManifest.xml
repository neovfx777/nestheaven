<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
      If Gradle minSdk is lower than a library's declared minSdk, manifest merger fails.
      We already set minSdk=26 in Gradle for MapKit, but this override keeps builds unblocked
      if a local config still evaluates to a lower minSdk (e.g., stale sync).
      NOTE: Running on API < 26 may crash at runtime.
    -->
    <uses-sdk tools:overrideLibrary="com.yandex.maps.mobile" />

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".NestHeavenApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:theme="@style/Theme.NestHeaven"
        android:usesCleartextTraffic="true">
        <activity
            android:name=".ComplexDetailActivity"
            android:exported="false" />
        <activity
            android:name=".ApartmentDetailActivity"
            android:exported="false" />
        <activity
            android:name=".LoginActivity"
            android:exported="false"
            android:theme="@style/Theme.NestHeaven.Auth"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".LoginVerificationActivity"
            android:exported="false"
            android:theme="@style/Theme.NestHeaven.Auth"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".RegisterActivity"
            android:exported="false"
            android:theme="@style/Theme.NestHeaven.Register"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".RegisterVerificationActivity"
            android:exported="false"
            android:theme="@style/Theme.NestHeaven.Auth"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".ChatActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".GetStartedActivity"
            android:exported="false" />
        <activity
            android:name=".YandexMapActivity"
            android:exported="false" />
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.NestHeaven.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
    </application>

</manifest>

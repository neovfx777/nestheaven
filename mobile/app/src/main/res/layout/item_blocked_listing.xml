<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/nh_border"
    app:strokeWidth="1dp"
    app:cardBackgroundColor="@color/nh_surface_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/blockedTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Listing title"
            android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
            android:textColor="@color/nh_text_primary"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/blockedMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Tashkent"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="@color/nh_text_secondary" />

        <TextView
            android:id="@+id/blockedPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="0 UZS"
            android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
            android:textColor="@color/nh_text_primary"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/blockedSystemMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_amenity_chip"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:text="@string/blocked_listing_system_message"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="@color/nh_text_secondary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/blockedUnblockButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/blocked_listing_unblock"
            app:backgroundTint="@color/nh_login_teal"
            android:textColor="@color/nh_surface" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>


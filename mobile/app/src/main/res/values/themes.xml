<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.NestHeaven" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/nh_blue_600</item>
        <item name="colorOnPrimary">@color/nh_text_inverse</item>
        <item name="colorPrimaryContainer">@color/nh_blue_50</item>
        <item name="colorOnPrimaryContainer">@color/nh_blue_700</item>
        <item name="colorSecondary">@color/nh_blue_700</item>
        <item name="colorOnSecondary">@color/nh_text_inverse</item>
        <item name="colorSurface">@color/nh_surface_card</item>
        <item name="colorOnSurface">@color/nh_text_primary</item>
        <item name="colorSurfaceVariant">@color/nh_surface_muted</item>
        <item name="colorOnSurfaceVariant">@color/nh_text_secondary</item>
        <item name="colorOutline">@color/nh_border</item>

        <item name="android:windowBackground">@color/nh_surface</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/nh_surface_card</item>
        <item name="android:navigationBarColor">@color/nh_surface_card</item>
    </style>

    <style name="Theme.NestHeaven.Splash" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/nh_splash_bg</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/nh_splash_bg</item>
        <item name="android:navigationBarColor">@color/nh_splash_bg</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.NestHeaven.Auth" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@drawable/bg_login_gradient</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/nh_splash_bg</item>
        <item name="android:navigationBarColor">@color/nh_login_teal</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
